# Hyperliquid
HL_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=
HL_API_URL=https://api.hyperliquid.xyz
HL_USE_TESTNET=true

# IBKR (TWS / IB Gateway must be running locally)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot
DB_PATH=./hip3_bot.db
LOG_LEVEL=INFO
SCAN_INTERVAL_SEC=30
DRY_RUN=true
HEDGE_VENUE=paper

# Strategy thresholds (defaults match spec)
MIN_ENTRY_APR_PCT=20
MAX_POSITION_PCT=0.10
KELLY_FRACTION=0.25
ROUND_TRIP_FEE_BPS=18
MIN_BOOK_DEPTH_USD=50000
LONG_SKEW_THRESHOLD=0.60
CONSECUTIVE_POSITIVE_FUNDING=3
DELTA_DRIFT_THRESHOLD=0.05
EXIT_APR_PCT=10
REBALANCE_INTERVAL_MIN=15
DEPLOYER_POLL_SEC=5
